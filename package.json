{
  "name": "relay-maryland",
  "type": "module",
  "version": "0.1.0",
  "homepage": "https://github.com/Relay-Maryland/relaymaryland.com",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build-and-preview": "npm run build && npm run preview",
    "test": "npm run test:prod",
    "test:dev": "CYPRESS_TEST_MODE=dev start-server-and-test dev http://localhost:4321 cypress:run",
    "test:prod": "CYPRESS_TEST_MODE=prod start-server-and-test build-and-preview http://localhost:4321 cypress:run",
    "test:dev:open": "CYPRESS_TEST_MODE=dev start-server-and-test dev http://localhost:4321 cypress:open",
    "test:prod:open": "CYPRESS_TEST_MODE=prod start-server-and-test build-and-preview http://localhost:4321 cypress:open",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "cypress": "^14.0.0",
    "start-server-and-test": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
